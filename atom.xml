class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br></pre></td><td class="code"><pre><span class="line">#include &lt;stdio.h&gt;</span><br><span class="line">int main()</span><br><span class="line">&#123;</span><br><span class="line">char i;</span><br><span class="line">int count=0;</span><br><span class="line">while((i=getchar())!=&#x27;\n&#x27;)&#123;</span><br><span class="line">    count++;</span><br><span class="line">&#125; </span><br><span class="line">printf(&quot;%d&quot;,count);</span><br><span class="line">  return 0;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
    
    
      
      
